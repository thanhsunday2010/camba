# Database — Supabase
# Vercel (bắt buộc): DATABASE_URL = Transaction pooler port 6543 + pgbouncer=true
# Ví dụ pooler (Supabase Dashboard → Connect → Transaction pooler):
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL = Session/direct port 5432 (migrate + seed):
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# NextAuth (v5 uses AUTH_SECRET; NEXTAUTH_SECRET also supported)
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
# Local: http://localhost:3000 | Vercel: https://YOUR-PROJECT.vercel.app (NOT localhost)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
AUTH_TRUST_HOST="true"

# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
# Auth-scoped OAuth keys (AQ.*) and standard keys (AIza*) both supported
GOOGLE_AI_API_KEY="your-google-ai-studio-api-key"
# Aliases: GEMINI_API_KEY, GOOGLE_API_KEY

# Optional: Vertex AI via Application Default Credentials
# GOOGLE_GENAI_USE_VERTEXAI="true"
# GOOGLE_CLOUD_PROJECT="your-gcp-project"
# GOOGLE_CLOUD_LOCATION="us-central1"

# Gemini models (optional — defaults to gemini-1.5-flash for lowest cost)
# Use gemini-1.5-pro for higher-quality writing/speaking feedback
GEMINI_MODEL_WRITING="gemini-2.5-flash"
GEMINI_MODEL_SPEAKING="gemini-2.5-flash"
GEMINI_MODEL_EXPLAIN="gemini-2.5-flash"
GEMINI_MODEL_AUDIO="gemini-2.5-flash"

# Higher quality (optional): gemini-2.5-pro or gemini-3.5-flash

# Speech-to-text for Speaking module:
# - "browser" (default, $0): Web Speech API on client — Chrome/Edge recommended
# - "gemini": upload audio to server → Gemini transcribes (uses AI Studio quota)
SPEECH_TO_TEXT_MODE="browser"

# Optional: Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: Facebook Login — https://developers.facebook.com/apps
# Valid OAuth Redirect URI: https://YOUR-DOMAIN/api/auth/callback/facebook
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# Camba bank transfer & VietQR (https://vietqr.io)
# CAMBA_PAYMENT_BANK_ONLY=false  # bật khi có VNPay/MoMo
CAMBA_BANK_NAME="ACB"
CAMBA_BANK_BIN="970416"
CAMBA_BANK_ACCOUNT="83993998"
CAMBA_BANK_HOLDER="NGUYEN TIEN THANH"
CAMBA_BANK_BRANCH=""

# VNPay sandbox — https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"

# MoMo test — https://developers.momo.vn
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"

# ZaloPay sandbox — https://docs.zalopay.vn
ZALOPAY_APP_ID=""
ZALOPAY_KEY1=""
ZALOPAY_KEY2=""
ZALOPAY_ENDPOINT="https://sb-openapi.zalopay.vn/v2/create"

# ShopeePay (optional)
SHOPEEPAY_MERCHANT_ID=""
SHOPEEPAY_SECRET_KEY=""

# Public app URL for payment callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"
