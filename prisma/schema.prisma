generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum ExamLevel {
  STARTERS
  MOVERS
  FLYERS
  KET
  PET
  FCE
}

enum Skill {
  READING
  WRITING
  LISTENING
  SPEAKING
  USE_OF_ENGLISH
}

enum QuestionType {
  MCQ
  GAP_FILL
  FREE_TEXT
  SPEAKING_PROMPT
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum PaperKind {
  PRACTICE
  MOCK_SKILL
  MOCK_FULL
  PLACEMENT
}

enum BugReportStatus {
  OPEN
  REVIEWED
  RESOLVED
}

enum SubscriptionPlan {
  FREE
  PRO
  VIP
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  BANK_TRANSFER
  MOMO
  VNPAY
  VISA
  ATM
  QR
  ZALOPAY
  SHOPEEPAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PromoBenefitType {
  FREE_PERIOD
  PERCENT_OFF
  FIXED_AMOUNT_OFF
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  dateOfBirth   DateTime? @db.Date
  role          Role      @default(STUDENT)
  grade         String?
  targetExam    ExamLevel @default(KET)
  streak        Int       @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  attempts      Attempt[]
  aiFeedbacks   AIFeedback[]
  assignedBy    Assignment[] @relation("AssignedBy")
  assignments   Assignment[] @relation("AssignedTo")
  bugReports    BugReport[]
  subscriptions UserSubscription[]
  paymentOrders PaymentOrder[]
  dailyUsage    DailyUsage[]
  promoRedemptions PromoRedemption[]
  adminRoleId   String?
  adminRole     AdminRole? @relation(fields: [adminRoleId], references: [id], onDelete: SetNull)
}

model AdminRole {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  permissions String[]
  isSystem    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Question {
  id            String       @id @default(cuid())
  type          QuestionType
  level         ExamLevel
  skill         Skill
  title         String?
  content       Json
  correctAnswer Json?
  rubric        Json?
  points        Int          @default(1)
  orderIndex    Int          @default(0)
  audioUrl      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  paperQuestions PaperQuestion[]
  answers        AttemptAnswer[]
  aiFeedbacks    AIFeedback[]
}

model ExamPaper {
  id          String    @id @default(cuid())
  title       String
  description String?
  level       ExamLevel
  skill       Skill
  paperKind   PaperKind @default(PRACTICE)
  sections    Json?
  timeLimit   Int?
  isMockTest  Boolean   @default(false)
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  questions   PaperQuestion[]
  attempts    Attempt[]
  assignments Assignment[]
}

model PaperQuestion {
  id         String   @id @default(cuid())
  paperId    String
  questionId String
  orderIndex Int      @default(0)

  paper    ExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([paperId, questionId])
}

model Attempt {
  id              String        @id @default(cuid())
  userId          String?
  paperId         String
  guestFullName   String?
  guestPhone      String?
  status          AttemptStatus @default(IN_PROGRESS)
  score           Float?
  maxScore        Float?
  placementReport Json?
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  timeSpent       Int?

  user    User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper   ExamPaper       @relation(fields: [paperId], references: [id], onDelete: Cascade)
  answers AttemptAnswer[]
}

model AttemptAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  questionId String
  answer     Json
  isCorrect  Boolean?
  score      Float?
  createdAt  DateTime @default(now())

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model AIFeedback {
  id             String   @id @default(cuid())
  userId         String
  questionId     String?
  attemptId      String?
  feedbackType   String
  inputText      String   @db.Text
  overallScore   Float?
  cambridgeBand  String?
  criteria       Json?
  errors         Json?
  suggestions    Json?
  improvedVersion String? @db.Text
  transcript     String?  @db.Text
  rawResponse    Json?
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)
}

model Assignment {
  id           String    @id @default(cuid())
  paperId      String
  teacherId    String
  studentId    String
  dueDate      DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  paper   ExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  teacher User      @relation("AssignedBy", fields: [teacherId], references: [id], onDelete: Cascade)
  student User      @relation("AssignedTo", fields: [studentId], references: [id], onDelete: Cascade)
}

model BugReport {
  id        String           @id @default(cuid())
  userId    String?
  userEmail String?
  userName  String?
  pageUrl   String?
  message   String           @db.Text
  imageData String?          @db.Text
  status    BugReportStatus  @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model UserSubscription {
  id           String             @id @default(cuid())
  userId       String
  plan         SubscriptionPlan
  billingCycle BillingCycle?
  status       SubscriptionStatus @default(ACTIVE)
  startsAt     DateTime           @default(now())
  expiresAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments PaymentOrder[]

  @@index([userId, status])
}

model PaymentOrder {
  id             String           @id @default(cuid())
  userId         String
  subscriptionId String?
  plan           SubscriptionPlan
  billingCycle   BillingCycle
  amount         Int
  originalAmount Int?
  promoCodeId    String?
  method         PaymentMethod
  status         PaymentStatus    @default(PENDING)
  transferCode   String?          @unique
  providerRef    String?
  paidAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  promoCode    PromoCode?        @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  redemption   PromoRedemption?

  @@index([userId, status])
  @@index([status, createdAt])
}

model PromoCode {
  id              String           @id @default(cuid())
  code            String           @unique
  description     String?
  plan            SubscriptionPlan
  billingCycle    BillingCycle     @default(MONTHLY)
  benefitType     PromoBenefitType @default(FREE_PERIOD)
  discountPercent Int?
  discountAmount  Int?
  maxRedemptions  Int?
  redemptionCount Int              @default(0)
  active          Boolean          @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?
  showInPopup     Boolean          @default(true)
  popupTitle      String?
  popupMessage    String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  redemptions PromoRedemption[]
  orders      PaymentOrder[]
}

model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  orderId     String?  @unique
  redeemedAt  DateTime @default(now())

  promoCode PromoCode     @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     PaymentOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([promoCodeId, userId])
  @@index([userId])
}

model DailyUsage {
  id                    String   @id @default(cuid())
  userId                String
  date                  DateTime @db.Date
  practiceCount         Int      @default(0)
  writingAiGradingCount Int      @default(0)
  speakingAiGradingCount Int     @default(0)
  readingAiGradingCount Int      @default(0)
  listeningAiGradingCount Int    @default(0)
  useOfEnglishAiGradingCount Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
